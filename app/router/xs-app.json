{
  "welcomeFile": "/suppliers/webapp/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/evaluation/(.*)$",
      "target": "/evaluation/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/catalog/(.*)$",
      "target": "/catalog/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/suppliers/webapp/(.*)$",
      "target": "$1",
      "localDir": "resources/suppliers/webapp",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^(.*)$",
      "target": "$1",
      "localDir": "resources",
      "authenticationType": "xsuaa"
    }
  ]
}
